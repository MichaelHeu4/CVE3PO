# Required: inventory endpoint in CVE3PO
SOFTWARE_API_URL=https://cve3po.example.com/extensions/agent/inventory/

# Auth header mode: bearer (Authorization: Bearer <token>) or x-api-key
SOFTWARE_API_AUTH=bearer

# Token for bearer or x-api-key mode
SOFTWARE_API_BEARER_TOKEN=replace_me

# Optional: force host IP instead of auto-detection
# HOST_IP=10.0.0.10

# Optional: only print payload, do not send
# DRY_RUN=true
